#| message: false
#| warning: false
library(tidyverse)
df <- read.csv("~/STAT1003 DOCS/ASSIGNMENT/gravitational_lenses.csv")
filtered_df <- df |>
filter(
!is.na(lens_redshift),
lens_type %in% c("galaxy", "cluster")
)
#| label: tbl-summary
#| tbl-cap: "Summary statistics of lens redshift by lens type"
filtered_df |>
group_by(lens_type) |>
summarise(
n = n(),
Mean = round(mean(lens_redshift), 3),
SD = round(sd(lens_redshift), 3),
Min = round(min(lens_redshift), 3),
Q1 = round(quantile(lens_redshift, 0.25), 3),
Median = round(median(lens_redshift), 3),
Q3 = round(quantile(lens_redshift, 0.75), 3),
Max = round(max(lens_redshift), 3)
) |>
knitr::kable()
#| label: fig-bartype
#| fig-cap: "Count of lens systems by lens type and grading"
df |>
filter(lens_type %in% c("galaxy", "cluster")) |>
ggplot(aes(x = lens_type, fill = grading)) +
geom_bar(position = "dodge") +
labs(x = "Lens Type", y = "Count", fill = "Grading") +
theme_minimal()
#| label: fig-redshift
#| fig-cap: "Distribution of lens redshift by lens type"
filtered_df |>
ggplot(aes(x = lens_redshift, fill = lens_type)) +
geom_histogram(bins = 40, alpha = 0.6, position = "identity") +
labs(x = "Lens Redshift", y = "Count", fill = "Lens Type") +
theme_minimal()
#| label: fig-boxplot
#| fig-cap: "Boxplot of lens redshift by lens type"
filtered_df |>
ggplot(aes(x = lens_type, y = lens_redshift, fill = lens_type)) +
geom_boxplot() +
labs(x = "Lens Type", y = "Lens Redshift", fill = "Lens Type") +
theme_minimal()
#| label: fig-skymap
#| fig-cap: "Sky distribution of gravitational lens candidates by lens type"
df |>
filter(lens_type %in% c("galaxy", "cluster")) |>
ggplot(aes(x = ra_deg, y = dec_deg, colour = lens_type)) +
geom_point(alpha = 0.3, size = 0.5) +
labs(x = "Right Ascension (degrees)", y = "Declination (degrees)", colour = "Lens Type") +
theme_minimal()
#| label: tbl-ttest
#| tbl-cap: "Two-sample Welch t-test results"
galaxy_z <- filtered_df |> filter(lens_type == "galaxy") |> pull(lens_redshift)
cluster_z <- filtered_df |> filter(lens_type == "cluster") |> pull(lens_redshift)
test_result <- t.test(galaxy_z, cluster_z)
tibble(
`t-statistic` = round(test_result$statistic, 4),
`df` = round(test_result$parameter, 1),
`p-value` = round(test_result$p.value, 4),
`Mean (galaxy)` = round(test_result$estimate[1], 4),
`Mean (cluster)` = round(test_result$estimate[2], 4)
) |>
knitr::kable()

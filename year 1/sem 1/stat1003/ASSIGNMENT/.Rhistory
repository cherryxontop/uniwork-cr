library(tidyverse)
library(dplyr)
library(readr)
library(readxl)
data1 <- read_csv("STAT1003 DOCS/midsem/data1.csv")
data2 <- read_excel("STAT1003 DOCS/midsem/data2.xlsx")
data3 <- read_csv("STAT1003 DOCS/midsem/data3.csv")
# QUESTION 2
data1 |>
filter(type == "Hospitalizations",
injury_mechanism == "Motor Vehicle Crashes") |>
arrange(number_est) |>
slice(1) |>
pull(age_group)
# QUESTION 3
help("filter_")
help("dplyr-package")
total <- data1 |>
filter(type == "Hospitalizations") |>
summarise(total = sum(number_est)) |>
pull(total)
aged_65_plus <- data1 |>
filter(data1$type == "Hospitalizations",
data1$age_group %in% c("65-74", "75+")) |>
summarise(total = sum(number_est)) |>
pull(total)
round(aged_65_plus / total, 2)
# QUESTION 5
library(tidyverse)
filter <- dplyr::filter
data1 <- read_csv("STAT1003 DOCS/midsem/data1.csv")
data3 <- read_csv("STAT1003 DOCS/midsem/data3.csv")
#pivotting
pop <- data3 |>
pivot_longer(everything(),
names_to = "age_group",
values_to = "population")
#deaths per age grp
deaths <- data1 |>
filter(type == "Deaths") |>
group_by(age_group) |>
summarise(total_deaths = sum(number_est))
#final calculation
deaths |>
left_join(population, by = "age_group") |>
mutate(rate = round(total_deaths / population * 100000)) |>
arrange(desc(rate)) |>
head(1)
# QUESTION 6
ggplot(data2, aes(x = year, y= rate_est_edv, fill = injury_mechanism)) +
geom_col() +
labs (title = "rate of TBI-related emergency department visits (by year)",
x = "year",
y = "rate",
fill = "injury mechanisms")
#we can see the purple area denoting the unintentional falls being the leading cause of emergency visits
# QUESTION 7
data1 |>
filter(type == "Deaths",
age_group == "5-14") |>
arrange(desc(number_est))
#based on the table created above, the most likely injury mechanism is MOTOR VEHICLE CRASHES, with a significantly large number of 326
# QUESTION 8
struck_byob_hosp <- data1 |>              #struck by object + hospitalised
filter(type == "Hospitalizations",
injury_mechanism == "Unintentionally struck by or against an object")
struck_byob_hosp
total <- sum(struck_byob_hosp$number_est)       #total hospitalisations of being unintentionally struck by an object
total
prob <- struck_byob_hosp |>
filter(age_group == "45-54")|>
pull(number_est)/total
round(prob, 4)
#out of the 7090 total hospitalisations of being unintentionally struck by an object, only 685 were in the 45-54 age group.
# QUESTION 9
lambda <- data2 |>
filter(year == 2006) |>
summarise(totalp = sum(number_est_edv)) |>
pull(totalp)
lambda    #=1551107
#P(X>1552400)
round(ppois(1552400, lambda = lambda, lower.tail = FALSE), 4)
# QUESTION 10
# total cases per group
summary <- data1 |>
group_by(age_group, type) |>
summarise(total = sum(number_est))
summary
#plotting above tibble
ggplot(summary, aes(x = age_group, y = total, fill = type)) +
geom_col(position = "dodge") +
labs(title = "TBI cases by age group and type (2014)",
x = "age group",
y = "number of cases",
fill = "type")
#hospitalizations increase from 8,971 (0–4 age group) to 93,320 (75+ age group)
#deaths increase from 806 (0–4 age group) to 15,562 (75+ age group)
#above two statements support the claim for these case types.
#however ED visits peak at 15–24 (466,740) and then at 75+ (611,682)
#so the claim does not hold uniformly across all TBI types
